{
  "name": "@heybeaux/lattice-adapter-mastra",
  "version": "0.1.0",
  "description": "Mastra adapter for Lattice — wraps Mastra workflow steps with State Contracts and Circuit Breakers",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "lattice",
    "mastra",
    "agent-coordination",
    "state-contract"
  ],
  "author": "heybeaux <https://heybeaux.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heybeaux/lattice.git",
    "directory": "packages/adapter-mastra"
  },
  "dependencies": {
    "@heybeaux/lattice-core": "workspace:*"
  },
  "peerDependencies": {
    "@mastra/core": ">=0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "zod": "^3.25.76"
  }
}

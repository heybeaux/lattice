{
  "name": "@heybeaux/aegis-collect",
  "version": "0.1.0",
  "description": "Live data-collection harness for Aegis: records every Claude Code tool-call decision and its outcome so we can grow a real training dataset for the AWM predictor.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "aegis-outcome": "./dist/outcome.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/outcome.ts src/build-dataset.ts --format esm --dts --sourcemap",
    "build-dataset": "node dist/build-dataset.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "keywords": [
    "ai",
    "agent",
    "governance",
    "harness",
    "aegis",
    "data-collection",
    "training"
  ],
  "author": "heybeaux <https://heybeaux.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heybeaux/lattice.git",
    "directory": "packages/aegis-collect"
  },
  "dependencies": {
    "@heybeaux/lattice-aegis": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

{
  "packId": "aegis-builtin-secrets",
  "version": "1.0.0",
  "source": "ported from AutoHarness autoharness/rules/builtin.py (secrets_in_content category)",
  "rules": [
    {
      "id": "secrets.openai-key",
      "category": "secrets",
      "severity": "critical",
      "description": "OpenAI API key (sk-...)",
      "match": {
        "kind": "regex",
        "pattern": "\\bsk-[A-Za-z0-9]{20,}",
        "target": "content"
      },
      "appliesTo": ["Write", "Edit"]
    },
    {
      "id": "secrets.openai-project-key",
      "category": "secrets",
      "severity": "critical",
      "description": "OpenAI project API key (sk-proj-...)",
      "match": {
        "kind": "regex",
        "pattern": "\\bsk-proj-[A-Za-z0-9_\\-]{10,}",
        "target": "content"
      },
      "appliesTo": ["Write", "Edit"]
    },
    {
      "id": "secrets.anthropic-key",
      "category": "secrets",
      "severity": "critical",
      "description": "Anthropic API key (sk-ant-...)",
      "match": {
        "kind": "regex",
        "pattern": "\\bsk-ant-[A-Za-z0-9\\-]{20,}",
        "target": "content"
      },
      "appliesTo": ["Write", "Edit"]
    },
    {
      "id": "secrets.github-token",
      "category": "secrets",
      "severity": "critical",
      "description": "GitHub personal access token / OAuth / app token",
      "match": {
        "kind": "regex",
        "pattern": "\\b(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]{20,}",
        "target": "content"
      },
      "appliesTo": ["Write", "Edit"]
    },
    {
      "id": "secrets.aws-access-key",
      "category": "secrets",
      "severity": "critical",
      "description": "AWS access key ID (AKIA...)",
      "match": {
        "kind": "regex",
        "pattern": "\\bAKIA[0-9A-Z]{16}\\b",
        "target": "content"
      },
      "appliesTo": ["Write", "Edit"]
    },
    {
      "id": "secrets.private-key-block",
      "category": "secrets",
      "severity": "critical",
      "description": "Private key block in content",
      "match": {
        "kind": "regex",
        "pattern": "-----BEGIN\\s+(RSA|EC|DSA|OPENSSH|PGP)?\\s*PRIVATE\\s+KEY-----",
        "target": "content"
      },
      "appliesTo": ["Write", "Edit"]
    },
    {
      "id": "secrets.slack-token",
      "category": "secrets",
      "severity": "critical",
      "description": "Slack token (xoxb-, xoxp-, etc.)",
      "match": {
        "kind": "regex",
        "pattern": "\\bxox[bprsao]-[A-Za-z0-9\\-]{10,}",
        "target": "content"
      },
      "appliesTo": ["Write", "Edit"]
    },
    {
      "id": "secrets.db-url-with-password",
      "category": "secrets",
      "severity": "critical",
      "description": "Database connection URL with embedded password",
      "match": {
        "kind": "regex",
        "pattern": "(postgres(ql)?|mysql|mongodb(\\+srv)?|redis|amqp)://[^:]+:[^@\\s]+@",
        "target": "content"
      },
      "appliesTo": ["Write", "Edit"]
    },
    {
      "id": "secrets.jwt",
      "category": "secrets",
      "severity": "critical",
      "description": "JWT token (eyJ...)",
      "match": {
        "kind": "regex",
        "pattern": "\\beyJ[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}",
        "target": "content"
      },
      "appliesTo": ["Write", "Edit"]
    },
    {
      "id": "secrets.generic-api-key-assignment",
      "category": "secrets",
      "severity": "critical",
      "description": "Generic API key assignment pattern (api_key=..., secret_key=...)",
      "match": {
        "kind": "regex",
        "pattern": "(api[_-]?key|api[_-]?secret|secret[_-]?key)\\s*[:=]\\s*['\"]?[A-Za-z0-9/+=_\\-]{20,}",
        "flags": "i",
        "target": "content"
      },
      "appliesTo": ["Write", "Edit"]
    }
  ]
}

{
  "name": "@heybeaux/aegis-bench",
  "version": "0.1.0",
  "description": "The first benchmark that measures whether an agent harness improves tool use over time, not just whether it blocks bad commands. Scores @heybeaux/lattice-aegis on a safety floor plus an adversarial tool-use value-proof.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "aegis-bench": "./dist/cli.js"
  },
  "files": [
    "dist",
    "results"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap",
    "gen": "node scripts/gen-aegis-chain.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "keywords": [
    "ai",
    "agent",
    "governance",
    "harness",
    "benchmark",
    "tool-use",
    "evaluation",
    "safety"
  ],
  "author": "heybeaux <https://heybeaux.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heybeaux/lattice.git",
    "directory": "packages/aegis-bench"
  },
  "dependencies": {
    "@heybeaux/lattice-aegis": "workspace:*"
  },
  "devDependencies": {
    "@heybeaux/aegis-label": "workspace:*",
    "@types/node": "^22.15.0",
    "eslint": "^9.27.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

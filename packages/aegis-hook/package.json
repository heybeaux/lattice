{
  "name": "@heybeaux/aegis-hook",
  "version": "0.1.0",
  "description": "The Claude Code PreToolUse hook that runs the Aegis governance engine live. Maps Claude Code's hook stdin into an Aegis ToolCall, evaluates the bundled rule packs, and emits the correct PreToolUse permission-decision schema. Ships a settings.json installer with the CORRECT nested matcher schema (the one AutoHarness shipped broken).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "aegis-hook": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "keywords": [
    "ai",
    "agent",
    "governance",
    "harness",
    "claude-code",
    "hook",
    "pretooluse",
    "tool-use",
    "safety"
  ],
  "author": "heybeaux <https://heybeaux.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heybeaux/lattice.git",
    "directory": "packages/aegis-hook"
  },
  "dependencies": {
    "@heybeaux/lattice-aegis": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "eslint": "^9.27.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
